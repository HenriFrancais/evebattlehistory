# Inbound bearer the NV Tools proxy sends; reject anything else with 401.
NV_TOKEN=dev-token-change-me

# Path prefix the app is mounted under in production (e.g. /br). Empty = root.
URL_PREFIX=

# Data source: "real" calls the NV Tools portal APIs; "demo" reads data_demo/.
DATA_SOURCE=demo

# Outbound NV Tools portal API (roster). SEPARATE bearer from NV_TOKEN.
NV_API_URL=https://tools.novacancies.space/api
NV_API_TOKEN=

# Persistence / uploads / caches.
DB_PATH=./var/db/nvbr.db
LOG_DIR=./var/logs
ESI_CACHE_DIR=./var/esi
SDE_DIR=./var/sde
MAX_LOG_MB=20

# Backups (rclone → Google Drive). Empty remote disables backups.
# Point at a DEDICATED Drive sub-folder so retention only prunes our snapshots.
BACKUP_RCLONE_REMOTE=
BACKUP_KEEP=30
BACKUP_HOUR=3
# Pull the latest snapshot on boot if local data is empty (recommended in prod).
RESTORE_ON_START=false

# Local dev only — never enable in production (bypasses the bearer check).
DEV_MODE=false
DEV_USER_RANK=
DEV_USER_TEAMS=

LOG_LEVEL=INFO
